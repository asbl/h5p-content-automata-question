[
  {
    "name": "contentType",
    "type": "select",
    "label": "Type",
    "description": "Type of H5P Content",
    "options": [
      {
        "value": "please_choose",
        "label": "Please choose"
      },
      {
        "value": "ide_only",
        "label": "Assignment only"
      },
      {
        "value": "text_only",
        "label": "Text only"
      },
      {
        "value": "text_and_ide",
        "label": "Text and automata assignment"
      }
    ],
    "default": "text_and_ide"
  },
  {
    "name": "contents",
    "type": "list",
    "label": "Content",
    "widget": "showWhen",
    "showWhen": {
      "rules": [
        {
          "field": "contentType",
          "equals": [
            "text_only",
            "text_and_ide"
          ]
        }
      ]
    },
    "description": "Text can contain markdown, images and automata examples.",
    "expanded": true,
    "field": {
      "name": "field",
      "type": "group",
      "label": "Field",
      "fields": [
        {
          "name": "type",
          "type": "select",
          "label": "Type",
          "options": [
            {
              "value": "text",
              "label": "Text"
            },
            {
              "value": "image",
              "label": "Image"
            },
            {
              "value": "code",
              "label": "Automaton"
            }
          ],
          "default": "text"
        },
        {
          "type": "text",
          "name": "text",
          "optional": true,
          "label": "Text",
          "description": "Write instructions as markdown.",
          "widget": "showWhen",
          "showWhen": {
            "rules": [
              {
                "field": "type",
                "equals": [
                  "text"
                ]
              }
            ],
            "widget": "codeWidget"
          },
          "options": [
            {
              "language": "markdown",
              "showAlways": true
            }
          ]
        },
        {
          "name": "image",
          "type": "image",
          "label": "Image",
          "optional": true,
          "widget": "showWhen",
          "showWhen": {
            "rules": [
              {
                "field": "type",
                "equals": [
                  "image"
                ]
              }
            ]
          }
        },
        {
          "type": "boolean",
          "name": "showEditor",
          "label": "Show Editor?",
          "default": true,
          "widget": "showWhen",
          "showWhen": {
            "rules": [
              {
                "field": "type",
                "equals": [
                  "code"
                ]
              }
            ]
          }
        },
        {
          "name": "automatonType",
          "type": "select",
          "label": "Automaton type",
          "default": "dfa",
          "widget": "showWhen",
          "showWhen": {
            "rules": [
              {
                "field": "type",
                "equals": [
                  "code"
                ]
              }
            ]
          },
          "options": [
            {
              "value": "dfa",
              "label": "DFA"
            },
            {
              "value": "nfa",
              "label": "NFA"
            }
          ]
        },
        {
          "name": "code",
          "type": "text",
          "label": "Automaton JSON",
          "description": "Automaton model as JSON.",
          "optional": true,
          "widget": "showWhen",
          "showWhen": {
            "rules": [
              {
                "field": "type",
                "equals": [
                  "code"
                ]
              }
            ],
            "widget": "codeWidget"
          },
          "options": [
            {
              "language": "json",
              "showAlways": true
            }
          ],
          "default": ""
        }
      ]
    }
  },
  {
    "name": "advancedOptions",
    "type": "group",
    "label": "Advanced Options",
    "fields": [
      {
        "name": "showConsole",
        "type": "boolean",
        "label": "Show console",
        "description": "If enabled, execution traces are shown below the editor.",
        "default": true
      },
      {
        "name": "enableSaveLoadButtons",
        "type": "boolean",
        "label": "Show save and load buttons",
        "description": "If enabled, learners can download their automaton JSON.",
        "default": false
      }
    ]
  },
  {
    "name": "editorSettings",
    "type": "group",
    "label": "Editor Settings",
    "expanded": true,
    "widget": "showWhen",
    "showWhen": {
      "rules": [
        {
          "field": "contentType",
          "equals": [
            "ide_only",
            "text_and_ide"
          ]
        }
      ]
    },
    "fields": [
      {
        "type": "text",
        "name": "instructions",
        "widget": "codeWidget",
        "optional": true,
        "label": "Instructions",
        "description": "Write instructions as markdown.",
        "options": [
          {
            "language": "markdown",
            "showAlways": true
          }
        ]
      },
      {
        "name": "instructionsImage",
        "type": "image",
        "label": "Instructions Image",
        "optional": true
      },
      {
        "name": "automatonType",
        "type": "select",
        "label": "Automaton type",
        "default": "dfa",
        "options": [
          {
            "value": "dfa",
            "label": "DFA"
          },
          {
            "value": "nfa",
            "label": "NFA"
          }
        ]
      },
      {
        "name": "startingCode",
        "type": "text",
        "widget": "codeWidget",
        "label": "Initial automaton JSON",
        "description": "Initial automaton model.",
        "default": "",
        "options": [
          {
            "language": "json",
            "showAlways": true
          }
        ]
      },
      {
        "name": "manualInput",
        "type": "text",
        "label": "Default input word",
        "optional": true,
        "default": ""
      }
    ]
  },
  {
    "name": "gradingSettings",
    "type": "group",
    "label": "Grading Settings",
    "expanded": true,
    "widget": "showWhen",
    "showWhen": {
      "rules": [
        {
          "field": "contentType",
          "equals": [
            "ide_only",
            "text_and_ide"
          ]
        }
      ]
    },
    "fields": [
      {
        "name": "gradingMethod",
        "type": "select",
        "label": "Grading method",
        "default": "byTestCases",
        "options": [
          {
            "value": "please_choose",
            "label": "Please choose"
          },
          {
            "value": "byTestCases",
            "label": "By test cases"
          },
          {
            "value": "bySolution",
            "label": "By solution automaton equivalence"
          }
        ]
      },
      {
        "name": "testCases",
        "type": "list",
        "label": "Test cases",
        "entity": "test case",
        "field": {
          "name": "testCase",
          "type": "group",
          "label": "Test case",
          "fields": [
            {
              "name": "input",
              "type": "text",
              "label": "Input word",
              "default": ""
            },
            {
              "name": "expectedAccepted",
              "type": "boolean",
              "label": "Should be accepted",
              "default": true
            }
          ]
        }
      },
      {
        "name": "solutionAutomaton",
        "type": "text",
        "widget": "showWhen",
        "label": "Solution automaton JSON",
        "description": "Reference automaton used for equivalence checking. Warning: visible in page source.",
        "default": "",
        "showWhen": {
          "rules": [
            {
              "field": "gradingMethod",
              "equals": [
                "bySolution"
              ]
            }
          ],
          "widget": "codeWidget"
        },
        "options": [
          {
            "language": "json",
            "showAlways": true
          }
        ]
      }
    ]
  }
]
